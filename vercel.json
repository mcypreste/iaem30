{
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    {
      "source": "/r/:slug",
      "destination": "https://ihylwxjxjajtdhsnlrfm.supabase.co/functions/v1/short-link/:slug"
    },
    {
      "source": "/p/:slug",
      "destination": "/api/p?slug=:slug"
    }
  ],
  "redirects": [
    {
      "source": "/",
      "has": [{ "type": "host", "value": "admin.iaem30.com.br" }],
      "destination": "https://iaem30.com.br/admin",
      "permanent": false
    },
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "admin.iaem30.com.br" }],
      "destination": "https://iaem30.com.br/admin",
      "permanent": false
    }
  ]
}
